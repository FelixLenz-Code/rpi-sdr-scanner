#!/bin/bash
set -e

INSTALL_DIR="/usr/share/sdr-scanner"
APP_USER="pi"

case "$1" in
    configure)

        # ── RTL-SDR: DVB-Treiber deaktivieren ──────────────────────────────
        if [ ! -f /etc/modprobe.d/blacklist-rtl.conf ]; then
            echo 'blacklist dvb_usb_rtl28xxu' > /etc/modprobe.d/blacklist-rtl.conf
            echo 'blacklist rtl2832' >> /etc/modprobe.d/blacklist-rtl.conf
            echo 'blacklist rtl2830' >> /etc/modprobe.d/blacklist-rtl.conf
        fi

        # ── RTL-SDR udev-Regeln ────────────────────────────────────────────
        if [ ! -f /etc/udev/rules.d/20-rtlsdr.rules ]; then
            cat > /etc/udev/rules.d/20-rtlsdr.rules << 'EOF'
SUBSYSTEM=="usb", ATTRS{idVendor}=="0bda", ATTRS{idProduct}=="2832", GROUP="plugdev", MODE="0666"
SUBSYSTEM=="usb", ATTRS{idVendor}=="0bda", ATTRS{idProduct}=="2838", GROUP="plugdev", MODE="0666"
EOF
            udevadm control --reload-rules 2>/dev/null || true
        fi

        # ── Gruppen-Mitgliedschaft ─────────────────────────────────────────
        if id "$APP_USER" >/dev/null 2>&1; then
            for GRP in plugdev gpio audio bluetooth dialout; do
                getent group "$GRP" >/dev/null 2>&1 && \
                    usermod -aG "$GRP" "$APP_USER" 2>/dev/null || true
            done
        fi

        # ── pyrtlsdr via pip (apt-Version ist veraltet) ───────────────────────
        pip3 install --break-system-packages -q pyrtlsdr lgpio 2>/dev/null || \
            pip3 install -q pyrtlsdr lgpio 2>/dev/null || true

        # ── Datenverzeichnis anlegen (bookmarks.db, WorkingDirectory) ────────
        mkdir -p /var/lib/sdr-scanner
        chown pi:pi /var/lib/sdr-scanner

        # ── config/-Verzeichnis für pi beschreibbar machen ────────────────
        # BT-Adresse und PPM-Kalibrierung schreiben settings.py + settings.py.bak.
        # .bak anlegen erfordert Schreibrechte auf das Verzeichnis, nicht nur die Datei.
        chown -R pi:pi /usr/share/sdr-scanner/config/ 2>/dev/null || true

        # ── /usr/bin/sdr-scanner Wrapper ───────────────────────────────────
        ln -sf "${INSTALL_DIR}/start_scanner.sh" /usr/bin/sdr-scanner

        # ── fstrim deaktivieren (SD-Karten-Hänger beim Boot) ──────────────
        systemctl mask fstrim.service fstrim.timer 2>/dev/null || true

        # ── sudoers: Hotspot-Toggle ohne Passwort ─────────────────────────
        cat > /etc/sudoers.d/sdr-hotspot << 'EOF'
pi ALL=(ALL) NOPASSWD: /usr/bin/systemctl start sdr_hotspot.service, /usr/bin/systemctl stop sdr_hotspot.service, /bin/bash /usr/share/sdr-scanner/hotspot/setup_hotspot.sh
EOF
        chmod 440 /etc/sudoers.d/sdr-hotspot

        # ── WLAN-Hotspot einrichten ────────────────────────────────────────
        # SKIP_APT=1: Pakete kommen aus Depends, kein zweites apt nötig
        if ip link show wlan0 >/dev/null 2>&1; then
            SKIP_APT=1 SCANNER_DIR="${INSTALL_DIR}" \
                bash "${INSTALL_DIR}/hotspot/setup_hotspot.sh" || true
        fi

        # ── Alte manuell installierte Service-Datei entfernen ─────────────
        # /etc/systemd/system/ überschreibt /lib/systemd/system/ – alte Datei
        # vom vorherigen install.sh-Setup würde den neuen Pfad blockieren.
        if [ -f /etc/systemd/system/sdr_scanner.service ]; then
            rm -f /etc/systemd/system/sdr_scanner.service
        fi

        # ── systemd: Scanner-Service aktivieren ───────────────────────────
        systemctl daemon-reload
        systemctl enable sdr_scanner 2>/dev/null || true
        systemctl start sdr_scanner 2>/dev/null || true

    ;;
esac
